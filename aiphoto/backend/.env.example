# AI Photo Agent Environment Variables

# Security
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql://user:password@localhost:5434/ai_photo_agent

# Redis
REDIS_URL=redis://localhost:6381

# File upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# AI Model settings
VISION_MODEL=qwen-vl
EDITING_MODEL=opencv

# CORS
CORS_ORIGINS=["http://localhost:3000"]