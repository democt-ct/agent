TEXT_API_KEY=ollama
TEXT_API_BASE=http://127.0.0.1:11434/v1/
TEXT_MODEL=modelscope.cn/unsloth/DeepSeek-R1-Distill-Qwen-7B-GGUF:latest
DEBUG_DB_PATH=./fastapi_debug/debug.db

# AMap / Gaode Map configuration
# Browser JS SDK key, used by the frontend map renderer
AMAP_BROWSER_KEY=
# Security JS code from AMap console, used by the frontend map renderer
AMAP_SECURITY_JS_CODE=
# Web service key, used only by the backend for POI search / route planning
AMAP_WEB_SERVICE_KEY=
# Default city and map center used when the user does not provide a location
AMAP_DEFAULT_CITY=绵阳
AMAP_DEFAULT_CENTER=104.679127,31.467673
# Default search radius for nearby POI search
AMAP_DEFAULT_RADIUS_METERS=3000
